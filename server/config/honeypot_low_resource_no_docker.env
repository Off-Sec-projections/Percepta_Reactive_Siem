# Percepta low-resource profile: production honeypot without Docker
# Target: constrained CPU/RAM/disk systems.

# ------------------------------
# Server-side pressure controls
# ------------------------------
PERCEPTA_MAX_IN_MEMORY_EVENTS=12000
PERCEPTA_STATS_INTERVAL_MS=3000
PERCEPTA_RETENTION_DAYS=14

# Keep Sigma focused/high-signal only on small machines.
PERCEPTA_SIGMA_ENABLED=1
PERCEPTA_SIGMA_SCOPE=windows,linux,auth
PERCEPTA_SIGMA_MIN_LEVEL=high
PERCEPTA_SIGMA_ALLOW_EXPERIMENTAL=0
PERCEPTA_SIGMA_MAX_FILES=900
PERCEPTA_SIGMA_MAX_RULES=1000
PERCEPTA_SIGMA_MAX_CONDITIONS=20
PERCEPTA_SIGMA_MAX_METADATA_RATIO=0.35
PERCEPTA_SIGMA_MAX_REGEX_CONDITIONS=1

# ---------------------------------
# Agent-side honeypot pressure caps
# ---------------------------------
# Cowrie log source
# PERCEPTA_COWRIE_JSON=/var/log/cowrie/cowrie.json

# Focused honeypot signal set.
PERCEPTA_COWRIE_EVENT_ALLOWLIST=cowrie.login.failed,cowrie.session.connect,cowrie.command.input,cowrie.session.closed,cowrie.login.success

# Skip oversized NDJSON lines to avoid memory spikes.
PERCEPTA_COWRIE_MAX_LINE_BYTES=8192

# Lower CPU/network churn on constrained endpoints.
PERCEPTA_COLLECT_INTERVAL_MS=3000
PERCEPTA_SHIPPER_INTERVAL_MS=8000
