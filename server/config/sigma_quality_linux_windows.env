# Percepta Sigma profile: quality-grade + low resource footprint (Linux + Windows)

# Enable Sigma runtime import
PERCEPTA_SIGMA_ENABLED=1

# Local SigmaHQ rules checkout (cloned under workspace)
PERCEPTA_SIGMA_DIR=sigma_sources/sigma/rules

# Staged high-signal scope (avoid broad noisy categories at first)
PERCEPTA_SIGMA_SCOPE=windows,linux,auth

# Keep only high-confidence content initially
PERCEPTA_SIGMA_MIN_LEVEL=high
PERCEPTA_SIGMA_ALLOW_EXPERIMENTAL=0

# CPU/RAM guardrails
PERCEPTA_SIGMA_MAX_FILES=1200
PERCEPTA_SIGMA_MAX_RULES=1500
PERCEPTA_SIGMA_MAX_CONDITIONS=24
PERCEPTA_SIGMA_MAX_REGEX_CONDITIONS=1
PERCEPTA_SIGMA_MAX_METADATA_RATIO=0.40

# Optional include/exclude path tokens (comma separated)
# PERCEPTA_SIGMA_INCLUDE=windows,linux,auth
# PERCEPTA_SIGMA_EXCLUDE=unsupported,deprecated,test