alert tcp $HOME_NET any -> $EXTERNAL_NET 3333 (msg:"PERCEPTA Crypto mining pool port 3333"; flow:to_server; classtype:trojan-activity; sid:9901804; rev:1;)

alert tcp $HOME_NET any -> $EXTERNAL_NET 14444 (msg:"PERCEPTA Crypto mining pool port 14444"; flow:to_server; classtype:trojan-activity; sid:9901805; rev:1;)

